" Blog post skeleton — fires when creating a new .md in posts/ or drafts/
autocmd BufNewFile */n0tls.github.io/{posts,drafts}/*.md call InsertPostTemplate()

function! InsertPostTemplate()
    let l:today = strftime('%Y-%m-%d')
    call setline(1, '---')
    call append(1, 'title: ')
    call append(2, 'date: ' . l:today)
    call append(3, 'tags:')
    call append(4, '  - ')
    call append(5, 'excerpt: ')
    call append(6, '---')
    call append(7, '')
    call append(8, '')
    " Place cursor at end of title line
    call cursor(2, 100)
    startinsert!
endfunction
